// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Player {
  id String @id @default(cuid())

  name    String @unique
  balance Int    @default(0)
  status  Status @default(OFFLINE)

  // :point_down: комментарии, где он "владелец"
  playerComments PlayerComment[] @relation("PlayerComments")

  // :point_down: комментарии, где он автор
  authoredComments PlayerComment[] @relation("AuthorComments")

  skin Json
}

model PlayerComment {
  id String @id @default(cuid())

  // :point_down: к кому относится комментарий
  player   Player @relation("PlayerComments", fields: [playerId], references: [id])
  playerId String

  content String
  createdAt DateTime @default(now())

  // :point_down: кто написал
  author   Player @relation("AuthorComments", fields: [authorId], references: [id])
  authorId String
}
enum Status {
  ONLINE
  OFFLINE
}