// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Player {
  id String @id @default(cuid())

  postLikes PostLike[]

  name    String @unique
  balance Int    @default(0)
  status  Status @default(OFFLINE)

  // :point_down: комментарии, где он "владелец"
  playerComments PlayerComment[] @relation("PlayerComments")

  // :point_down: комментарии, где он автор
  authoredComments PlayerComment[] @relation("AuthorComments")

  comments Comment[]
  posts    Post[]

  playerCommentLikes PlayerCommentLike[]

  skin String @default("https://nmsr.nickac.dev/bust/alex")
  background String @default("transparent")
}

model PlayerComment {
  id String @id @default(cuid())

  // :point_down: к кому относится комментарий
  player   Player @relation("PlayerComments", fields: [playerId], references: [id])
  playerId String

  content   String
  createdAt DateTime @default(now())

  // :point_down: кто написал
  author   Player @relation("AuthorComments", fields: [authorId], references: [id])
  authorId String

  likes PlayerCommentLike[]
}

enum Status {
  ONLINE
  OFFLINE
}

model Comment {
  id String @id @default(cuid())

  content   String
  createdAt DateTime @default(now())

  // :point_down: кто написал
  author   Player @relation(fields: [authorId], references: [id])
  authorId String

  post   Post   @relation(fields: [postId], references: [id])
  postId String
}

model Post {
  id String @id @default(cuid())

  content   String
  createdAt DateTime @default(now())

  // :point_down: кто написал
  author   Player @relation(fields: [authorId], references: [id])
  authorId String

  likes PostLike[]

  comments Comment[]
}

model PostLike {
  id String @id @default(cuid())

  author   Player @relation(fields: [authorId], references: [id])
  authorId String

  posts Post[]
}

model PlayerCommentLike {
  id String @id @default(cuid())

  author   Player @relation(fields: [authorId], references: [id])
  authorId String

  playerComment   PlayerComment @relation(fields: [playerCommentId], references: [id])
  playerCommentId String
}
