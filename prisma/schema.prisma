// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Player {
  id String @id @default(cuid())

  name    String @unique
  balance Int    @default(0)
  status  Status @default(OFFLINE)

  // :point_down: комментарии, где он "владелец"
  playerComments Comment[] @relation("PlayerComments")
  comments       Comment[] @relation("AuthoredComments")

  sourceTransfers Transfer[] @relation("SourcePlayer")
  targetTransfers Transfer[] @relation("TargetPlayer")

  friendshipSender   Friendship[] @relation("FriendshipSender")
  friendshipReceiver Friendship[] @relation("FriendshipReceiver")

  posts Post[]
  roles Role[]

  likes Like[]

  views        View[]
  achievements Achievement[]

  skin String
  texture String

  colors     Color[]
  accent     String
  opacity String

  @@index([name])
}

model Role {
  id      String   @id @default(cuid())
  value   String   @unique
  players Player[]
}

enum Status {
  ONLINE
  OFFLINE
}

model Color {
  id      String   @id @default(cuid())
  value   String   @unique
  players Player[]
}

model Friendship {
  id String @id @default(cuid())

  sender   Player @relation("FriendshipSender", fields: [senderId], references: [id])
  senderId String

  receiver   Player @relation("FriendshipReceiver", fields: [receiverId], references: [id])
  receiverId String

  answer Answer @default(PENDING)

  createdAt DateTime @default(now())
}

enum Answer {
  PENDING
  ACCEPTED
  DECLINED
}

model Comment {
  id String @id @default(cuid())

  content   String
  createdAt DateTime @default(now())

  // :point_down: кто написал
  author   Player @relation("AuthoredComments", fields: [authorId], references: [id])
  authorId String

  post   Post?   @relation(fields: [postId], references: [id])
  postId String?

  player   Player? @relation("PlayerComments", fields: [playerId], references: [id])
  playerId String?

  likes Like[]
}

model Post {
  id String @id @default(cuid())

  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  author   Player? @relation(fields: [authorId], references: [id])
  authorId String?

  images Image[]

  likes    Like[]
  views    View[]
  comments Comment[]
}

model Like {
  id String @id @default(cuid())

  author   Player @relation(fields: [authorId], references: [id])
  authorId String

  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  commentId String?

  post   Post?   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String?
}

model View {
  id       String @id @default(cuid())
  player   Player @relation(fields: [playerId], references: [id])
  playerId String

  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String
}

model Image {
  id String @id @default(cuid())

  post   Post?   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String?

  record   Record? @relation(fields: [recordId], references: [id], onDelete: Cascade)
  recordId String?

  donate      Donate?
  achievement Achievement?

  ufsUrl String
  name   String
  key    String
  size    Int
}

model Transfer {
  id String @id @default(cuid())

  source   Player? @relation("SourcePlayer", fields: [sourceId], references: [id])
  sourceId String?

  target   Player? @relation("TargetPlayer", fields: [targetId], references: [id])
  targetId String?

  comment String?

  amount Int

  time DateTime @default(now())
}

model Donate {
  id          String @id @default(cuid())
  param       String @unique
  name        String
  description String
  content     String @default("")
  cost        String @default("100.00")

  image   Image  @relation(fields: [imageId], references: [id])
  imageId String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchases Purchase[]
}

model Purchase {
  id     String @id @default(cuid())
  player String

  donate   Donate @relation(fields: [donateId], references: [id])
  donateId String
}

model Achievement {
  id          String @id @default(cuid())
  name        String
  description String

  image   Image  @relation(fields: [imageId], references: [id])
  imageId String @unique

  players Player[]
}

model Record {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  images Image[]
}
