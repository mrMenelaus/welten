// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Player {
  id String @id @default(cuid())

  name    String @unique
  balance Int    @default(0)
  status  Status @default(OFFLINE)

  // :point_down: комментарии, где он "владелец"
  playerComments Comment[] @relation("PlayerComments")

  sourceTransfers Transfer[] @relation("SourcePlayer")
  targetTransfers Transfer[] @relation("TargetPlayer")

  comments Comment[] @relation("AuthoredComments")
  posts    Post[]
  roles    Role[]

  likes Like[]

  views View[]

  skin       String @default("https://nmsr.nickac.dev/bust/alex")
  background String @default("transparent")
}

model Role {
  id      String   @id @default(cuid())
  value   String   @unique
  players Player[]
}

enum Status {
  ONLINE
  OFFLINE
}

model Comment {
  id String @id @default(cuid())

  content   String
  createdAt DateTime @default(now())

  // :point_down: кто написал
  author   Player @relation("AuthoredComments", fields: [authorId], references: [id])
  authorId String

  post   Post?   @relation(fields: [postId], references: [id])
  postId String?

  player   Player? @relation("PlayerComments", fields: [playerId], references: [id])
  playerId String?

  likes Like[]
}

model Post {
  id String @id @default(cuid())

  content   String
  createdAt DateTime @default(now())

  // :point_down: кто написал
  author   Player @relation(fields: [authorId], references: [id])
  authorId String

  images Image[]

  likes    Like[]
  views    View[]
  comments Comment[]
}

model Like {
  id String @id @default(cuid())

  author   Player @relation(fields: [authorId], references: [id])
  authorId String

  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  commentId String?

  post   Post?   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String?
}

model View {
  id       String @id @default(cuid())
  player   Player @relation(fields: [playerId], references: [id])
  playerId String

  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String
}

model Image {
  id     String @id @default(cuid())
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String

  ufsUrl String
  name   String
}

model Transfer {
  id String @id @default(cuid())

  source   Player? @relation("SourcePlayer", fields: [sourceId], references: [id])
  sourceId String?

  target   Player? @relation("TargetPlayer", fields: [targetId], references: [id])
  targetId String?

  comment String?

  amount Int

  time DateTime @default(now())
}
